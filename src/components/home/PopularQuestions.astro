---
import type { CollectionEntry } from 'astro:content';
import AnswerCard from '../ui/AnswerCard.astro';

interface Props {
  answers: CollectionEntry<'answers'>[];
}

const { answers } = Astro.props;
---

<section class="py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs font-semibold text-sage uppercase tracking-widest mb-2">Popular</p>
        <h2 class="font-display text-3xl font-bold text-charcoal">Popular Questions</h2>
      </div>
      <a href="/answers" class="text-sm font-medium text-rose-gold hover:text-rose-gold-light transition-colors hidden sm:block">
        View all answers →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {answers.map(answer => (
        <AnswerCard answer={answer} />
      ))}
    </div>

    <div class="mt-6 text-center sm:hidden">
      <a href="/answers" class="text-sm font-medium text-rose-gold hover:text-rose-gold-light transition-colors">
        View all answers →
      </a>
    </div>
  </div>
</section>
