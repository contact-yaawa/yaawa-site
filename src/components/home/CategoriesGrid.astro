---
import CategoryCard from '../ui/CategoryCard.astro';

interface Category {
  id: string;
  data: { name: string; description: string; icon: string };
}

interface Props {
  categories: Category[];
  answerCounts?: Record<string, number>;
}

const { categories, answerCounts = {} } = Astro.props;
---

<section class="py-16 px-4 sm:px-6 lg:px-8 bg-champagne/30">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-xs font-semibold text-sage uppercase tracking-widest mb-2">Browse by Topic</p>
      <h2 class="font-display text-3xl font-bold text-charcoal">Explore Categories</h2>
      <p class="mt-3 text-charcoal-light max-w-xl mx-auto">
        Find answers organized by the topics that matter most in wedding planning.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {categories.map(cat => (
        <CategoryCard
          name={cat.data.name}
          slug={cat.id}
          description={cat.data.description}
          icon={cat.data.icon}
          count={answerCounts[cat.id]}
        />
      ))}
    </div>
  </div>
</section>
