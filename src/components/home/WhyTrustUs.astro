---
const points = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" /></svg>`,
    title: 'Real Questions, Real People',
    body: 'Our questions are sourced from genuine wedding planning discussions — the same questions couples are actually asking online.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>`,
    title: 'Balanced Perspectives',
    body: 'Our answers synthesize multiple viewpoints — traditional etiquette, modern thinking, and practical reality — without pushing one agenda.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    title: 'Practical, Unbiased Guidance',
    body: 'Every answer is designed to help you make a confident decision — not to sell you something or judge your choices.',
  },
];
---

<section class="py-16 px-4 sm:px-6 lg:px-8 bg-charcoal text-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-champagne uppercase tracking-widest mb-2">Why YAAWA</p>
      <h2 class="font-display text-3xl font-bold text-white">
        Advice You Can Actually Trust
      </h2>
      <p class="mt-3 text-white/60 max-w-xl mx-auto">
        Wedding planning is full of opinions. We cut through the noise with clear, balanced, practical answers.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {points.map(point => (
        <div class="flex flex-col items-start">
          <div class="w-12 h-12 rounded-xl bg-rose-gold/20 flex items-center justify-center text-rose-gold mb-4" set:html={point.icon} />
          <h3 class="font-display text-xl font-semibold text-white mb-2">{point.title}</h3>
          <p class="text-white/60 text-sm leading-relaxed">{point.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
