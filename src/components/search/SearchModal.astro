---
// Pagefind search modal — only functional in built output (not dev server)
---

<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Search">
  <div class="absolute inset-0 bg-charcoal/50 backdrop-blur-sm" id="search-modal-backdrop"></div>
  <div class="relative z-10 flex items-start justify-center pt-20 px-4">
    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden">
      <div class="p-4 border-b border-champagne flex items-center justify-between">
        <span class="font-display text-lg font-semibold text-charcoal">Search YAAWA</span>
        <button id="search-modal-close" class="p-1.5 rounded-lg hover:bg-champagne transition-colors text-charcoal-light" aria-label="Close search">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="p-4" id="pagefind-search-container">
        <!-- Pagefind UI mounts here -->
      </div>
      <p class="px-4 pb-4 text-xs text-charcoal-light/60 text-center">
        Search is powered by Pagefind. Results appear as you type.
      </p>
    </div>
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

<script>
  async function initPagefind() {
    const container = document.getElementById('pagefind-search-container');
    if (!container) return;

    try {
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js' as string);
      new PagefindUI({
        element: '#pagefind-search-container',
        showSubResults: true,
        resetStyles: false,
      });
    } catch {
      if (container) {
        container.innerHTML = '<p class="text-sm text-charcoal-light py-4 text-center">Search is only available in the built version of this site.</p>';
      }
    }
  }

  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-modal-backdrop');
  const closeBtn = document.getElementById('search-modal-close');

  let initialized = false;

  function openModal() {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (!initialized) {
      initialized = true;
      initPagefind();
    }
    setTimeout(() => {
      const input = modal?.querySelector('input[type="text"]') as HTMLInputElement;
      input?.focus();
    }, 100);
  }

  function closeModal() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
  });

  // Wire up any search trigger buttons on the page
  document.querySelectorAll('[data-search-trigger]').forEach(btn => {
    btn.addEventListener('click', openModal);
  });
</script>

<style>
  /* Override Pagefind default styles to match our palette */
  :root {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: #B76E79;
    --pagefind-ui-text: #333333;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #E8DCCB;
    --pagefind-ui-tag: #F8F5F0;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Inter', system-ui, sans-serif;
  }
</style>
