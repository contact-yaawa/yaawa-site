---
import type { CollectionEntry } from 'astro:content';
import Badge from './Badge.astro';

interface Props {
  answer: CollectionEntry<'answers'>;
}

const { answer } = Astro.props;
const { title, excerpt, category, created } = answer.data;
const slug = answer.slug;

const date = new Date(created).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article
  class="group bg-white border border-champagne hover:border-sage rounded-xl p-6 transition-all hover:shadow-md"
  data-category={category}
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 mb-3">
        <Badge label={category} href={`/categories/${category}`} variant="default" />
        <time class="text-xs text-charcoal-light" datetime={new Date(created).toISOString()}>
          {date}
        </time>
      </div>
      <h3 class="font-display text-xl font-semibold text-charcoal group-hover:text-rose-gold transition-colors mb-2 leading-snug">
        <a href={`/answers/${slug}`} class="hover:underline underline-offset-2">
          {title}
        </a>
      </h3>
      <p class="text-sm text-charcoal-light leading-relaxed line-clamp-2">{excerpt}</p>
    </div>
    <div class="flex-shrink-0 text-champagne group-hover:text-rose-gold transition-colors mt-1">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</article>
