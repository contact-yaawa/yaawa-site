---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb">
  <ol class="flex items-center gap-2 text-sm text-charcoal-light flex-wrap">
    {crumbs.map((crumb, i) => (
      <>
        <li>
          {crumb.href ? (
            <a href={crumb.href} class="hover:text-rose-gold transition-colors">
              {crumb.label}
            </a>
          ) : (
            <span class="text-charcoal font-medium" aria-current="page">{crumb.label}</span>
          )}
        </li>
        {i < crumbs.length - 1 && (
          <li aria-hidden="true" class="text-champagne">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </li>
        )}
      </>
    ))}
  </ol>
</nav>
