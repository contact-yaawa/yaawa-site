---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import CategoryCard from '../../components/ui/CategoryCard.astro';

const allCategories = await getCollection('categories');
const allAnswers = await getCollection('answers');

const answerCounts: Record<string, number> = {};
allAnswers.forEach(a => {
  answerCounts[a.data.category] = (answerCounts[a.data.category] || 0) + 1;
});

const canonicalURL = new URL('/categories', Astro.site).toString();
---

<BaseLayout
  title="Wedding Answer Categories"
  description="Browse wedding questions and answers by category — from etiquette and budget to guest lists, venues, vendors, and more."
  canonicalURL={canonicalURL}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <p class="text-xs font-semibold text-sage uppercase tracking-widest mb-2">Browse by Topic</p>
      <h1 class="font-display text-4xl font-bold text-charcoal mb-4">Categories</h1>
      <p class="text-charcoal-light max-w-2xl">
        Every wedding planning topic, organized so you can find exactly what you're looking for.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
      {allCategories.map(cat => (
        <CategoryCard
          name={cat.data.name}
          slug={cat.id}
          description={cat.data.description}
          icon={cat.data.icon}
          count={answerCounts[cat.id] ?? 0}
        />
      ))}
    </div>
  </div>
</BaseLayout>
