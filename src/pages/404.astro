---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import SearchBar from '../components/search/SearchBar.astro';

const allAnswers = await getCollection('answers');
const popularAnswers = allAnswers
  .sort((a, b) => b.data.created.getTime() - a.data.created.getTime())
  .slice(0, 4);
---

<BaseLayout
  title="Page Not Found — YAAWA"
  description="We couldn't find the page you were looking for. Search our wedding answers or head back home."
>
  <section class="bg-ivory pt-16 pb-24 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <!-- Subtle decorative background (matches Hero) -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-champagne/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-sage/10 blur-3xl -translate-x-1/2 translate-y-1/2"></div>
      <div class="absolute top-1/4 right-1/4 w-72 h-72 rounded-full bg-rose-gold/5 blur-3xl"></div>
    </div>

    <div class="max-w-2xl mx-auto text-center relative">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 text-xs font-medium text-rose-gold uppercase tracking-widest mb-8 bg-rose-gold/10 px-4 py-2 rounded-full">
        <span>Error 404</span>
      </div>

      <!-- Big 404 with a ring motif for the zero -->
      <div class="flex items-center justify-center gap-3 sm:gap-5 mb-6 font-display font-bold text-charcoal leading-none select-none">
        <span class="text-8xl sm:text-9xl">4</span>
        <span class="relative inline-flex items-center justify-center text-8xl sm:text-9xl text-rose-gold">
          <!-- Diamond ring stands in for the "0" -->
          <svg class="w-24 h-24 sm:w-32 sm:h-32" viewBox="0 0 100 100" fill="none" aria-hidden="true">
            <path d="M32 30 L50 14 L68 30 L50 40 Z" fill="currentColor" opacity="0.85" />
            <path d="M32 30 L50 40 L40 30 Z" fill="currentColor" opacity="0.55" />
            <path d="M68 30 L50 40 L60 30 Z" fill="currentColor" opacity="0.55" />
            <circle cx="50" cy="66" r="24" stroke="currentColor" stroke-width="7" fill="none" />
          </svg>
        </span>
        <span class="text-8xl sm:text-9xl">4</span>
      </div>

      <!-- Headline -->
      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal leading-tight mb-5">
        Looks like this page
        <span class="text-rose-gold italic">got cold feet</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg text-charcoal-light max-w-xl mx-auto leading-relaxed mb-10">
        The page you're looking for wandered off before the big day. Let's help you find your way back to the answers that matter.
      </p>

      <!-- Search -->
      <div class="max-w-lg mx-auto mb-8">
        <SearchBar size="lg" placeholder="Search wedding questions..." />
      </div>

      <!-- CTAs -->
      <div class="flex items-center justify-center gap-4 flex-wrap mb-16">
        <a
          href="/"
          class="px-6 py-3 bg-rose-gold text-white font-medium rounded-xl hover:bg-rose-gold-light transition-colors shadow-sm"
        >
          Back to Home
        </a>
        <a
          href="/answers"
          class="px-6 py-3 bg-white border border-champagne text-charcoal font-medium rounded-xl hover:border-sage transition-colors"
        >
          Browse All Answers
        </a>
      </div>

      <!-- Popular questions -->
      {popularAnswers.length > 0 && (
        <div class="max-w-xl mx-auto text-left">
          <p class="text-xs font-medium text-charcoal-light uppercase tracking-widest text-center mb-5">
            Or explore a popular question
          </p>
          <ul class="space-y-3">
            {popularAnswers.map(answer => (
              <li>
                <a
                  href={`/answers/${answer.slug}`}
                  class="group flex items-center justify-between gap-4 bg-white border border-champagne hover:border-sage rounded-xl px-5 py-4 transition-all hover:shadow-md"
                >
                  <span class="font-display text-base sm:text-lg text-charcoal group-hover:text-rose-gold transition-colors leading-snug">
                    {answer.data.title}
                  </span>
                  <svg class="w-5 h-5 flex-shrink-0 text-champagne group-hover:text-rose-gold transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
