---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import AnswerCard from '../../components/ui/AnswerCard.astro';
import SearchBar from '../../components/search/SearchBar.astro';

const allAnswers = await getCollection('answers');
const allCategories = await getCollection('categories');

const sorted = allAnswers.sort((a, b) => b.data.created.getTime() - a.data.created.getTime());

const canonicalURL = new URL('/answers', Astro.site).toString();
---

<BaseLayout
  title="All Wedding Answers"
  description="Browse all wedding Q&A answers on YAAWA. Searchable and filterable by category — from etiquette and budget to guest lists and family issues."
  canonicalURL={canonicalURL}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page header -->
    <div class="mb-10">
      <p class="text-xs font-semibold text-sage uppercase tracking-widest mb-2">All Answers</p>
      <h1 class="font-display text-4xl font-bold text-charcoal mb-4">Wedding Questions Answered</h1>
      <p class="text-charcoal-light max-w-2xl">
        Browse every question and answer on YAAWA. Filter by category or search to find exactly what you need.
      </p>
    </div>

    <!-- Search + Filter -->
    <div class="flex flex-col sm:flex-row gap-4 mb-8">
      <div class="flex-1">
        <SearchBar placeholder="Search answers..." size="md" />
      </div>
      <div class="sm:w-56">
        <select
          id="category-filter"
          class="w-full bg-white border border-champagne rounded-xl py-3.5 px-4 text-charcoal text-sm focus:outline-none focus:border-sage focus:ring-2 focus:ring-sage/20 transition-all"
          aria-label="Filter by category"
        >
          <option value="">All Categories</option>
          {allCategories.map(cat => (
            <option value={cat.data.slug}>{cat.data.name}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Answer count -->
    <p class="text-sm text-charcoal-light mb-6" id="answer-count">
      Showing <span id="visible-count">{sorted.length}</span> of {sorted.length} answers
    </p>

    <!-- Answer grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="answers-grid">
      {sorted.map(answer => (
        <AnswerCard answer={answer} />
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-charcoal-light text-lg font-display">No answers found in this category yet.</p>
      <a href="/answers" class="mt-4 inline-block text-sm text-rose-gold hover:text-rose-gold-light transition-colors">
        Clear filter →
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  const filter = document.getElementById('category-filter') as HTMLSelectElement;
  const grid = document.getElementById('answers-grid');
  const emptyState = document.getElementById('empty-state');
  const visibleCount = document.getElementById('visible-count');

  filter?.addEventListener('change', () => {
    const value = filter.value;
    const cards = grid?.querySelectorAll<HTMLElement>('[data-category]') ?? [];
    let shown = 0;

    cards.forEach(card => {
      const match = !value || card.dataset.category === value;
      card.style.display = match ? '' : 'none';
      if (match) shown++;
    });

    if (visibleCount) visibleCount.textContent = String(shown);
    emptyState?.classList.toggle('hidden', shown > 0);
    grid?.classList.toggle('hidden', shown === 0);
  });

  // Handle ?q= param from search form — could redirect to pagefind results
  const params = new URLSearchParams(window.location.search);
  const q = params.get('q');
  if (q) {
    const searchInput = document.querySelector<HTMLInputElement>('input[name="q"]');
    if (searchInput) searchInput.value = q;
  }
</script>
